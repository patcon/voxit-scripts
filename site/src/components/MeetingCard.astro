---
import { formatGroupName } from '../lib/meetingNotes.js';
const { meeting } = Astro.props;
const { group, slug, date, title, isPrivate, hasRedaction, preview } = meeting;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<a
  href={`${base}${group}/${slug}/`}
  class="block bg-white rounded-lg border border-gray-200 p-5 hover:border-teal-400 hover:shadow-sm transition"
>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1 flex-wrap">
        <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-teal-50 text-teal-700 border border-teal-100">
          {formatGroupName(group)}
        </span>
        {isPrivate && (
          <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-slate-100 text-slate-600">
            Private
          </span>
        )}
        {hasRedaction && !isPrivate && (
          <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 border border-amber-100">
            Redacted
          </span>
        )}
      </div>
      <h3 class="font-medium text-gray-900 truncate">{title}</h3>
      {preview && !isPrivate && (
        <p class="text-sm text-gray-500 mt-1 line-clamp-2">{preview}</p>
      )}
    </div>
    {date && (
      <span class="text-xs text-gray-400 whitespace-nowrap mt-0.5">{date}</span>
    )}
  </div>
</a>
