---
const { url } = Astro.props;
---
<div class="bg-amber-50 border border-amber-200 rounded-lg px-5 py-4 flex items-start gap-3">
  <span class="text-amber-500 text-lg leading-tight mt-0.5" aria-hidden="true">&#9619;</span>
  <div class="text-sm">
    <span class="font-medium text-amber-800">This note contains redacted content.</span>
    <span class="text-amber-700 ml-1">
      Redacted sections are shown as &#9608; blocks.
      <a href={url} class="underline hover:text-amber-900">View unredacted version in private repo &rarr;</a>
    </span>
  </div>
</div>
