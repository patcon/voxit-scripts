---
import Layout from '../../layouts/Layout.astro';
import MeetingCard from '../../components/MeetingCard.astro';
import { getAllGroups, getMeetingsForGroup, formatGroupName } from '../../lib/meetingNotes.js';

export async function getStaticPaths() {
  const groups = getAllGroups();
  return groups.map(group => ({ params: { group } }));
}

const { group } = Astro.params;
const meetings = getMeetingsForGroup(group);
const groupName = formatGroupName(group);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<Layout title={groupName}>
  <div class="space-y-6">
    <nav class="text-sm text-gray-500 flex items-center gap-1.5">
      <a href={base} class="hover:text-teal-600">Home</a>
      <span>/</span>
      <span class="text-gray-900">{groupName}</span>
    </nav>

    <div>
      <h1 class="text-2xl font-bold text-gray-900">{groupName}</h1>
      <p class="text-gray-500 mt-1">{meetings.length} meeting{meetings.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="space-y-4">
      {meetings.map(meeting => (
        <MeetingCard meeting={meeting} />
      ))}
      {meetings.length === 0 && (
        <p class="text-gray-500">No meetings yet.</p>
      )}
    </div>
  </div>
</Layout>
