---
import Layout from '../../layouts/Layout.astro';
import RedactionBanner from '../../components/RedactionBanner.astro';
import { getAllGroups, getMeetingsForGroup, formatGroupName } from '../../lib/meetingNotes.js';
import { marked } from 'marked';

export async function getStaticPaths() {
  const groups = getAllGroups();
  return groups.flatMap(group =>
    getMeetingsForGroup(group).map(meeting => ({
      params: { group, slug: meeting.slug },
      props: { meeting },
    }))
  );
}

const { meeting } = Astro.props;
const { group, filename, title, date, isPrivate, hasRedaction, content } = meeting;
const groupName = formatGroupName(group);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const privateRepoUrl = `https://github.com/patcon/voxit-scripts-private/blob/main/meeting-notes/${group}/${filename}`;
const html = !isPrivate ? marked.parse(content) : '';
---
<Layout title={title}>
  <div class="space-y-6">
    <nav class="text-sm text-gray-500 flex items-center gap-1.5">
      <a href={base} class="hover:text-teal-600">Home</a>
      <span>/</span>
      <a href={`${base}${group}/`} class="hover:text-teal-600">{groupName}</a>
      <span>/</span>
      <span class="text-gray-900">{date}</span>
    </nav>

    {isPrivate ? (
      <div class="bg-slate-50 border border-slate-200 rounded-lg p-10 text-center space-y-3">
        <div class="text-4xl" aria-hidden="true">&#128274;</div>
        <h1 class="text-2xl font-bold text-gray-900">{title}</h1>
        <p class="text-gray-600">This meeting took place on {date}.</p>
        <p class="text-gray-500">Full notes are in the private archive.</p>
        <a href={privateRepoUrl} class="inline-block mt-2 text-sm text-teal-700 hover:underline">
          View in private repo &rarr;
        </a>
      </div>
    ) : (
      <div class="space-y-5">
        {hasRedaction && <RedactionBanner url={privateRepoUrl} />}
        <article
          class="bg-white rounded-lg border border-gray-200 p-6 prose prose-teal max-w-none [overflow-wrap:anywhere]"
          set:html={html}
        />
      </div>
    )}
  </div>
</Layout>
