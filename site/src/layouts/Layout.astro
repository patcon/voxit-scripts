---
const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | Voxit Meeting Notes` : 'Voxit Meeting Notes'}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans min-h-screen flex flex-col">
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
      <div class="max-w-4xl mx-auto px-4 py-3">
        <a href={base} class="font-semibold text-teal-700 hover:text-teal-600 text-lg">
          Voxit Meeting Notes
        </a>
      </div>
    </header>
    <main class="flex-1 max-w-4xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>
    <footer class="bg-white border-t border-gray-200 text-center text-sm text-gray-500 py-4">
      <a href="https://github.com/patcon/voxit-scripts" class="hover:underline">
        patcon/voxit-scripts
      </a>
    </footer>
  </body>
</html>
